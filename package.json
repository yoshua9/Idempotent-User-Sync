{
  "name": "idempotent-user-sync",
  "version": "1.0.0",
  "description": "Microservicio REST con idempotencia usando UPSERT en PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "pretest": "ts-node tests/setup.ts",
    "test": "DATABASE_URL=postgres://user:pass@localhost:5432/dbname_test JWT_SECRET=test-secret jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
